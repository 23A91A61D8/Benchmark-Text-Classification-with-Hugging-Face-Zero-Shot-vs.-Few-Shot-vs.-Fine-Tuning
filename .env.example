# ---------------------------------------------------------------------------
# Copy this file to .env and adjust as needed. docker-compose already loads
# .env.example by default so the project runs out of the box; override any
# value here (or in a real .env) to tune the run.
# ---------------------------------------------------------------------------
# Dataset
DATASET_NAME=ag_news
NUM_LABELS=4
# Zero-shot
ZERO_SHOT_MODEL=MoritzLaurer/deberta-v3-base-zeroshot-v1.1-all-33
ZERO_SHOT_EVAL_SIZE=500
# Few-shot (SetFit)
FEW_SHOT_MODEL=sentence-transformers/all-MiniLM-L6-v2
FEW_SHOT_KS=2,4,8,16
FEW_SHOT_EVAL_SIZE=500
FEW_SHOT_SENSITIVITY_K=8
FEW_SHOT_SENSITIVITY_RUNS=3
# Fine-tuning
FINE_TUNE_MODEL=distilbert-base-uncased
FINE_TUNE_EPOCHS=2
FINE_TUNE_BATCH_SIZE=32
FINE_TUNE_LR=5e-5
FINE_TUNE_MAX_LENGTH=128
FINE_TUNE_TRAIN_SIZE=10000
FINE_TUNE_EVAL_SIZE=1000
DATA_EFFICIENCY_SIZES=100,500,2000,5000,10000
DATA_EFFICIENCY_EPOCHS=2
# Latency benchmarking
LATENCY_WARMUP_RUNS=5
LATENCY_MEASURED_RUNS=50
LATENCY_BATCH_SIZES=1,128
# Misc
SEED=42
OUTPUT_DIR=/app/results
LOG_LEVEL=INFO